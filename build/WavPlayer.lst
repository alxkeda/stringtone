 167:WavPlayer.cpp **** //  Position estimation
 168:WavPlayer.cpp **** // ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 169:WavPlayer.cpp **** 
 170:WavPlayer.cpp **** /**
 171:WavPlayer.cpp ****  * Compute a deviation-weighted centroid position for one column's sensor array.
 172:WavPlayer.cpp ****  *
 173:WavPlayer.cpp ****  * At idle (no magnet, all sensors near baseline), w_total < 1e-9 and
 174:WavPlayer.cpp ****  * current_pos is returned unchanged.  Because current_pos is initialised to
 175:WavPlayer.cpp ****  * ZERO_ROW (3.5), PosToAmplitude returns 0.0 ŌåÆ silence with no input.
 176:WavPlayer.cpp ****  *
 177:WavPlayer.cpp ****  * When a magnet is present the centroid naturally interpolates between adjacent
 178:WavPlayer.cpp ****  * sensors, giving sub-sensor resolution for free.  Dead-zone hysteresis
 179:WavPlayer.cpp ****  * prevents small noise perturbations from registering as position changes.
 180:WavPlayer.cpp ****  *
 181:WavPlayer.cpp ****  * @param voltages     NUM_ROWS sensor voltages for this column (volts).
 182:WavPlayer.cpp ****  * @param baselines    NUM_ROWS per-sensor calibration baselines (volts).
 183:WavPlayer.cpp ****  * @param current_pos  Previous position estimate [0.0, 7.0].
 184:WavPlayer.cpp ****  * @return             Updated (or held) position in [0.0, 7.0].
 185:WavPlayer.cpp ****  */
 186:WavPlayer.cpp **** static float UpdatePosition(const float *voltages, const float *baselines, float current_pos)
 187:WavPlayer.cpp **** {
ARM GAS  /var/folders/th/s5djnwg15xxc0dk87c413f_h0000gn/T//ccCW3aXI.s 			page 12


 188:WavPlayer.cpp ****     float w_sum   = 0.0f;
 189:WavPlayer.cpp ****     float w_total = 0.0f;
 190:WavPlayer.cpp **** 
 191:WavPlayer.cpp ****     for (int r = 0; r < NUM_ROWS; r++) {
 192:WavPlayer.cpp ****         float dev = fabsf(voltages[r] - baselines[r]);
 193:WavPlayer.cpp ****         if (dev > kNoiseFloor) {
 194:WavPlayer.cpp ****             w_sum   += static_cast<float>(r) * dev;
 195:WavPlayer.cpp ****             w_total += dev;
 196:WavPlayer.cpp ****         }
 197:WavPlayer.cpp ****     }
 198:WavPlayer.cpp **** 
 199:WavPlayer.cpp ****     if (w_total < 1e-9f)
 200:WavPlayer.cpp ****         return current_pos; // hold at ZERO_ROW when no sensor is active
 201:WavPlayer.cpp **** 
 202:WavPlayer.cpp ****     const float new_pos = w_sum / w_total;
 203:WavPlayer.cpp ****     return (fabsf(new_pos - current_pos) > kPosDead) ? new_pos : current_pos;
 204:WavPlayer.cpp **** }
 205:WavPlayer.cpp **** 
 206:WavPlayer.cpp **** /**
 207:WavPlayer.cpp ****  * Map a continuous row position to audio amplitude.
 208:WavPlayer.cpp ****  *
 209:WavPlayer.cpp ****  * The mapping is a single symmetric linear expression:
 210:WavPlayer.cpp ****  *
 211:WavPlayer.cpp ****  *   A(p) = (p ŌłÆ ZERO_ROW) / ZERO_ROW
 212:WavPlayer.cpp ****  *
 213:WavPlayer.cpp ****  * With ZERO_ROW = 3.5 and p Ōłł [0, 7]:
 214:WavPlayer.cpp ****  *   p = 0.0  ŌåÆ A = ŌłÆ1.0
 215:WavPlayer.cpp ****  *   p = 3.5  ŌåÆ A =  0.0   ŌåÉ idle / neutral
 216:WavPlayer.cpp ****  *   p = 7.0  ŌåÆ A = +1.0
 217:WavPlayer.cpp ****  *
 218:WavPlayer.cpp ****  * Because UpdatePosition initialises and holds at ZERO_ROW, all control
 219:WavPlayer.cpp ****  * points evaluate to exactly 0.0 when no magnet is present.
 220:WavPlayer.cpp ****  */
 221:WavPlayer.cpp **** static float PosToAmplitude(float p)
 222:WavPlayer.cpp **** {
 223:WavPlayer.cpp ****     return (p - ZERO_ROW) / ZERO_ROW;
 224:WavPlayer.cpp **** }
 225:WavPlayer.cpp **** 
 226:WavPlayer.cpp **** // ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 227:WavPlayer.cpp **** //  Wavetable builder ŌĆö Catmull-Rom cubic Hermite interpolation
 228:WavPlayer.cpp **** // ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 229:WavPlayer.cpp **** 
 230:WavPlayer.cpp **** /**
 231:WavPlayer.cpp ****  * Fill `table` (WAVETABLE_SIZE samples) by Catmull-Rom cubic Hermite
 232:WavPlayer.cpp ****  * interpolation over CTRL_PTS uniformly-spaced control points.
 233:WavPlayer.cpp ****  *
 234:WavPlayer.cpp ****  * Tangents (local parameter space, one unit per segment):
 235:WavPlayer.cpp ****  *   m[0]       = pts[1] ŌłÆ pts[0]                 forward difference
 236:WavPlayer.cpp ****  *   m[k]       = (pts[k+1] ŌłÆ pts[k-1]) / 2       central difference (interior)
 237:WavPlayer.cpp ****  *   m[CTRL-1]  = pts[CTRL-1] ŌłÆ pts[CTRL-2]       backward difference
 238:WavPlayer.cpp ****  *
 239:WavPlayer.cpp ****  * Cubic Hermite basis on segment [k, k+1], t Ōłł [0,1]:
 240:WavPlayer.cpp ****  *   p(t) = h00┬ĘpŌéĆ + h10┬ĘmŌéĆ + h01┬ĘpŌéü + h11┬ĘmŌéü
 241:WavPlayer.cpp ****  *   h00 =  2t┬│ ŌłÆ 3t┬▓ + 1
 242:WavPlayer.cpp ****  *   h10 =   t┬│ ŌłÆ 2t┬▓ + t
 243:WavPlayer.cpp ****  *   h01 = ŌłÆ2t┬│ + 3t┬▓
 244:WavPlayer.cpp ****  *   h11 =   t┬│ ŌłÆ  t┬▓
ARM GAS  /var/folders/th/s5djnwg15xxc0dk87c413f_h0000gn/T//ccCW3aXI.s 			page 13


 245:WavPlayer.cpp ****  *
 246:WavPlayer.cpp ****  * Output is clamped to [ŌłÆ1, 1] to guard against minor interpolation overshoot.
 247:WavPlayer.cpp ****  */
 248:WavPlayer.cpp **** static void BuildWavetable(float *table, const float *pts)
 249:WavPlayer.cpp **** {
 250:WavPlayer.cpp ****     const float s = (1.0f - kSplineTension);
 251:WavPlayer.cpp ****     float m[CTRL_PTS];
 252:WavPlayer.cpp ****     m[0]          = s * (pts[1] - pts[0]);
 253:WavPlayer.cpp ****     m[CTRL_PTS-1] = s * (pts[CTRL_PTS-1] - pts[CTRL_PTS-2]);
 254:WavPlayer.cpp ****     for (int k = 1; k < CTRL_PTS - 1; k++)
 255:WavPlayer.cpp ****         m[k] = s * (pts[k+1] - pts[k-1]) * 0.5f;
 256:WavPlayer.cpp **** 
 257:WavPlayer.cpp ****     for (int i = 0; i < WAVETABLE_SIZE; i++) {
 258:WavPlayer.cpp ****         const float tau = static_cast<float>(i) / static_cast<float>(WAVETABLE_SIZE);
 259:WavPlayer.cpp ****         const float ts  = tau * static_cast<float>(CTRL_PTS - 1);
 260:WavPlayer.cpp **** 
 261:WavPlayer.cpp ****         int         seg = static_cast<int>(ts);
 262:WavPlayer.cpp ****         if (seg >= CTRL_PTS - 1) seg = CTRL_PTS - 2;
 263:WavPlayer.cpp ****         const float t   = ts - static_cast<float>(seg);
 264:WavPlayer.cpp ****         const float t2  = t * t;
 265:WavPlayer.cpp ****         const float t3  = t2 * t;
 266:WavPlayer.cpp **** 
 267:WavPlayer.cpp ****         const float h00 =  2.f*t3 - 3.f*t2 + 1.f;
 268:WavPlayer.cpp ****         const float h10 =      t3 - 2.f*t2 + t;
 269:WavPlayer.cpp ****         const float h01 = -2.f*t3 + 3.f*t2;
 270:WavPlayer.cpp ****         const float h11 =      t3 -     t2;
 271:WavPlayer.cpp **** 
 272:WavPlayer.cpp ****         float v = h00 * pts[seg]
 273:WavPlayer.cpp ****                 + h10 * m[seg]
 274:WavPlayer.cpp ****                 + h01 * pts[seg + 1]
 275:WavPlayer.cpp ****                 + h11 * m[seg + 1];
 276:WavPlayer.cpp **** 
 277:WavPlayer.cpp ****         table[i] = fmaxf(-1.0f, fminf(v, 1.0f));
 278:WavPlayer.cpp ****     }
 279:WavPlayer.cpp **** }
