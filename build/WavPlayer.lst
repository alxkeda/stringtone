 146:WavPlayer.cpp ****     sel_gpio[1].Write((addr >> 1) & 1u);
 147:WavPlayer.cpp ****     sel_gpio[2].Write((addr >> 2) & 1u);
 148:WavPlayer.cpp **** }
 149:WavPlayer.cpp **** 
 150:WavPlayer.cpp **** static inline void SetChannelAddr(uint8_t addr)
 151:WavPlayer.cpp **** {
