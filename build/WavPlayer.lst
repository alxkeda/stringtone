 154:WavPlayer.cpp ****     ch_gpio[1].Write((addr >> 1) & 1u);
 155:WavPlayer.cpp ****     ch_gpio[2].Write((addr >> 2) & 1u);
 156:WavPlayer.cpp **** }
 157:WavPlayer.cpp **** 
 158:WavPlayer.cpp **** static void GetMuxAddrs(int col, int row, uint8_t &sel, uint8_t &ch)
 159:WavPlayer.cpp **** {
 160:WavPlayer.cpp ****     const int col_pair = col / 2;
 161:WavPlayer.cpp ****     const int ch_base  = (col % 2 == 0) ? 4 : 0;
 162:WavPlayer.cpp ****     sel = static_cast<uint8_t>(col_pair * 2 + (row >= 4 ? 1 : 0));
 163:WavPlayer.cpp ****     ch  = static_cast<uint8_t>(ch_base  + (row % 4));
 164:WavPlayer.cpp **** }
