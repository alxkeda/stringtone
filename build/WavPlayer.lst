 144:WavPlayer.cpp **** static inline void SetSelectorAddr(uint8_t addr)
 145:WavPlayer.cpp **** {
 146:WavPlayer.cpp ****     sel_gpio[0].Write((addr >> 0) & 1u);
 147:WavPlayer.cpp ****     sel_gpio[1].Write((addr >> 1) & 1u);
 148:WavPlayer.cpp ****     sel_gpio[2].Write((addr >> 2) & 1u);
 149:WavPlayer.cpp **** }
 150:WavPlayer.cpp **** 
 151:WavPlayer.cpp **** static inline void SetChannelAddr(uint8_t addr)
 152:WavPlayer.cpp **** {
