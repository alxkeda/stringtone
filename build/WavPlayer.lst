 166:WavPlayer.cpp **** //  Position estimation
 167:WavPlayer.cpp **** // ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 168:WavPlayer.cpp **** 
 169:WavPlayer.cpp **** /**
 170:WavPlayer.cpp ****  * Compute a deviation-weighted centroid position for one column's sensor array.
 171:WavPlayer.cpp ****  *
 172:WavPlayer.cpp ****  * At idle (no magnet, all sensors near baseline), w_total < 1e-9 and
 173:WavPlayer.cpp ****  * current_pos is returned unchanged.  Because current_pos is initialised to
 174:WavPlayer.cpp ****  * ZERO_ROW (3.5), PosToAmplitude returns 0.0 ŌåÆ silence with no input.
 175:WavPlayer.cpp ****  *
 176:WavPlayer.cpp ****  * When a magnet is present the centroid naturally interpolates between adjacent
 177:WavPlayer.cpp ****  * sensors, giving sub-sensor resolution for free.  Dead-zone hysteresis
 178:WavPlayer.cpp ****  * prevents small noise perturbations from registering as position changes.
 179:WavPlayer.cpp ****  *
 180:WavPlayer.cpp ****  * @param voltages     NUM_ROWS sensor voltages for this column (volts).
 181:WavPlayer.cpp ****  * @param baselines    NUM_ROWS per-sensor calibration baselines (volts).
 182:WavPlayer.cpp ****  * @param current_pos  Previous position estimate [0.0, 7.0].
 183:WavPlayer.cpp ****  * @return             Updated (or held) position in [0.0, 7.0].
 184:WavPlayer.cpp ****  */
 185:WavPlayer.cpp **** static float UpdatePosition(const float *voltages, const float *baselines, float current_pos)
 186:WavPlayer.cpp **** {
 187:WavPlayer.cpp ****     float w_sum   = 0.0f;
ARM GAS  /var/folders/th/s5djnwg15xxc0dk87c413f_h0000gn/T//ccXOGyQC.s 			page 12


 188:WavPlayer.cpp ****     float w_total = 0.0f;
 189:WavPlayer.cpp **** 
 190:WavPlayer.cpp ****     for (int r = 0; r < NUM_ROWS; r++) {
 191:WavPlayer.cpp ****         float dev = fabsf(voltages[r] - baselines[r]);
 192:WavPlayer.cpp ****         if (dev > kNoiseFloor) {
 193:WavPlayer.cpp ****             w_sum   += static_cast<float>(r) * dev;
 194:WavPlayer.cpp ****             w_total += dev;
 195:WavPlayer.cpp ****         }
 196:WavPlayer.cpp ****     }
 197:WavPlayer.cpp **** 
 198:WavPlayer.cpp ****     if (w_total < 1e-9f)
 199:WavPlayer.cpp ****         return current_pos; // hold at ZERO_ROW when no sensor is active
 200:WavPlayer.cpp **** 
 201:WavPlayer.cpp ****     const float new_pos = w_sum / w_total;
 202:WavPlayer.cpp ****     return (fabsf(new_pos - current_pos) > kPosDead) ? new_pos : current_pos;
 203:WavPlayer.cpp **** }
 204:WavPlayer.cpp **** 
 205:WavPlayer.cpp **** /**
 206:WavPlayer.cpp ****  * Map a continuous row position to audio amplitude.
 207:WavPlayer.cpp ****  *
 208:WavPlayer.cpp ****  * The mapping is a single symmetric linear expression:
 209:WavPlayer.cpp ****  *
 210:WavPlayer.cpp ****  *   A(p) = (p ŌłÆ ZERO_ROW) / ZERO_ROW
 211:WavPlayer.cpp ****  *
 212:WavPlayer.cpp ****  * With ZERO_ROW = 3.5 and p Ōłł [0, 7]:
 213:WavPlayer.cpp ****  *   p = 0.0  ŌåÆ A = ŌłÆ1.0
 214:WavPlayer.cpp ****  *   p = 3.5  ŌåÆ A =  0.0   ŌåÉ idle / neutral
 215:WavPlayer.cpp ****  *   p = 7.0  ŌåÆ A = +1.0
 216:WavPlayer.cpp ****  *
 217:WavPlayer.cpp ****  * Because UpdatePosition initialises and holds at ZERO_ROW, all control
 218:WavPlayer.cpp ****  * points evaluate to exactly 0.0 when no magnet is present.
 219:WavPlayer.cpp ****  */
 220:WavPlayer.cpp **** static float PosToAmplitude(float p)
 221:WavPlayer.cpp **** {
 222:WavPlayer.cpp ****     return (p - ZERO_ROW) / ZERO_ROW;
 223:WavPlayer.cpp **** }
 224:WavPlayer.cpp **** 
 225:WavPlayer.cpp **** // ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 226:WavPlayer.cpp **** //  Wavetable builder ŌĆö Catmull-Rom cubic Hermite interpolation
 227:WavPlayer.cpp **** // ŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉŌĢÉ
 228:WavPlayer.cpp **** 
 229:WavPlayer.cpp **** /**
 230:WavPlayer.cpp ****  * Fill `table` (WAVETABLE_SIZE samples) by Catmull-Rom cubic Hermite
 231:WavPlayer.cpp ****  * interpolation over CTRL_PTS uniformly-spaced control points.
 232:WavPlayer.cpp ****  *
 233:WavPlayer.cpp ****  * Tangents (local parameter space, one unit per segment):
 234:WavPlayer.cpp ****  *   m[0]       = pts[1] ŌłÆ pts[0]                 forward difference
 235:WavPlayer.cpp ****  *   m[k]       = (pts[k+1] ŌłÆ pts[k-1]) / 2       central difference (interior)
 236:WavPlayer.cpp ****  *   m[CTRL-1]  = pts[CTRL-1] ŌłÆ pts[CTRL-2]       backward difference
 237:WavPlayer.cpp ****  *
 238:WavPlayer.cpp ****  * Cubic Hermite basis on segment [k, k+1], t Ōłł [0,1]:
 239:WavPlayer.cpp ****  *   p(t) = h00┬ĘpŌéĆ + h10┬ĘmŌéĆ + h01┬ĘpŌéü + h11┬ĘmŌéü
 240:WavPlayer.cpp ****  *   h00 =  2t┬│ ŌłÆ 3t┬▓ + 1
 241:WavPlayer.cpp ****  *   h10 =   t┬│ ŌłÆ 2t┬▓ + t
 242:WavPlayer.cpp ****  *   h01 = ŌłÆ2t┬│ + 3t┬▓
 243:WavPlayer.cpp ****  *   h11 =   t┬│ ŌłÆ  t┬▓
 244:WavPlayer.cpp ****  *
ARM GAS  /var/folders/th/s5djnwg15xxc0dk87c413f_h0000gn/T//ccXOGyQC.s 			page 13


 245:WavPlayer.cpp ****  * Output is clamped to [ŌłÆ1, 1] to guard against minor interpolation overshoot.
 246:WavPlayer.cpp ****  */
 247:WavPlayer.cpp **** static void BuildWavetable(float *table, const float *pts)
 248:WavPlayer.cpp **** {
 249:WavPlayer.cpp ****     const float s = (1.0f - kSplineTension);
 250:WavPlayer.cpp ****     float m[CTRL_PTS];
 251:WavPlayer.cpp ****     m[0]          = s * (pts[1] - pts[0]);
 252:WavPlayer.cpp ****     m[CTRL_PTS-1] = s * (pts[CTRL_PTS-1] - pts[CTRL_PTS-2]);
 253:WavPlayer.cpp ****     for (int k = 1; k < CTRL_PTS - 1; k++)
 254:WavPlayer.cpp ****         m[k] = s * (pts[k+1] - pts[k-1]) * 0.5f;
 255:WavPlayer.cpp **** 
 256:WavPlayer.cpp ****     for (int i = 0; i < WAVETABLE_SIZE; i++) {
 257:WavPlayer.cpp ****         const float tau = static_cast<float>(i) / static_cast<float>(WAVETABLE_SIZE);
 258:WavPlayer.cpp ****         const float ts  = tau * static_cast<float>(CTRL_PTS - 1);
 259:WavPlayer.cpp **** 
 260:WavPlayer.cpp ****         int         seg = static_cast<int>(ts);
 261:WavPlayer.cpp ****         if (seg >= CTRL_PTS - 1) seg = CTRL_PTS - 2;
 262:WavPlayer.cpp ****         const float t   = ts - static_cast<float>(seg);
 263:WavPlayer.cpp ****         const float t2  = t * t;
 264:WavPlayer.cpp ****         const float t3  = t2 * t;
 265:WavPlayer.cpp **** 
 266:WavPlayer.cpp ****         const float h00 =  2.f*t3 - 3.f*t2 + 1.f;
 267:WavPlayer.cpp ****         const float h10 =      t3 - 2.f*t2 + t;
 268:WavPlayer.cpp ****         const float h01 = -2.f*t3 + 3.f*t2;
 269:WavPlayer.cpp ****         const float h11 =      t3 -     t2;
 270:WavPlayer.cpp **** 
 271:WavPlayer.cpp ****         float v = h00 * pts[seg]
 272:WavPlayer.cpp ****                 + h10 * m[seg]
 273:WavPlayer.cpp ****                 + h01 * pts[seg + 1]
 274:WavPlayer.cpp ****                 + h11 * m[seg + 1];
 275:WavPlayer.cpp **** 
 276:WavPlayer.cpp ****         table[i] = fmaxf(-1.0f, fminf(v, 1.0f));
 277:WavPlayer.cpp ****     }
 278:WavPlayer.cpp **** }
 279:WavPlayer.cpp **** 
