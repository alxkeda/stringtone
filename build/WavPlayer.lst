 157:WavPlayer.cpp **** static void GetMuxAddrs(int col, int row, uint8_t &sel, uint8_t &ch)
 158:WavPlayer.cpp **** {
 159:WavPlayer.cpp ****     const int col_pair = col / 2;
 160:WavPlayer.cpp ****     const int ch_base  = (col % 2 == 0) ? 4 : 0;
 161:WavPlayer.cpp ****     sel = static_cast<uint8_t>(col_pair * 2 + (row >= 4 ? 1 : 0));
 162:WavPlayer.cpp ****     ch  = static_cast<uint8_t>(ch_base  + (row % 4));
 163:WavPlayer.cpp **** }
